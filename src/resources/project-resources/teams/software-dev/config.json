{
  "team": "software-dev",
  "displayName": "Software Developer",
  "version": 1,
  "models": {
    "claude-cli": {
      "allowed": ["opus", "sonnet", "haiku"],
      "defaults": {
        "sm": "sonnet",
        "dev": "sonnet",
        "review": "opus",
        "tester": "sonnet"
      }
    },
    "gemini-cli": {
      "allowed": ["gemini-2.5-pro", "gemini-2.5-flash"],
      "defaults": {
        "sm": "gemini-2.5-flash",
        "dev": "gemini-2.5-pro",
        "review": "gemini-2.5-pro",
        "tester": "gemini-2.5-flash"
      }
    }
  },
  "stages": [
    {
      "name": "sm",
      "displayName": "Scrum Master",
      "icon": "📋",
      "prompt": "./prompts/sm.md",
      "timeout": 600,
      "workers": 1,
      "retries": 0,
      "next": "dev"
    },
    {
      "name": "dev",
      "displayName": "Developer",
      "icon": "⚙️",
      "prompt": "./prompts/dev.md",
      "timeout": 900,
      "workers": 1,
      "retries": 0,
      "next": "review",
      "reject_to": "dev"
    },
    {
      "name": "review",
      "displayName": "Reviewer",
      "icon": "🔍",
      "prompt": "./prompts/review.md",
      "timeout": 600,
      "workers": 1,
      "retries": 3,
      "next": "tester",
      "reject_to": "dev"
    },
    {
      "name": "tester",
      "displayName": "Tester",
      "icon": "✅",
      "prompt": "./prompts/tester.md",
      "timeout": 600,
      "workers": 1,
      "retries": 3,
      "reject_to": "dev"
    }
  ]
}
