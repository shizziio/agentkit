{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "noImplicitAny": false,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@providers/*": ["./src/providers/*"],
      "@ui/*": ["./src/ui/*"],
      "@workers/*": ["./src/workers/*"],
      "@config/*": ["./src/config/*"],
      "@cli/*": ["./src/cli/*"],
      "@shared/*": ["./src/shared/*"]
    },
    "types": ["vitest/globals"]
  },
  "include": ["tests/**/*"],
  "references": [
    { "path": "./tsconfig.src.json" }
  ]
}
